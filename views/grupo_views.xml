<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_grupo_tree" model="ir.ui.view">
        <field name="name">gestion.grupo.tree</field>
        <field name="model">gestion.grupo</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nombre"/>
                <field name="denominacion"/>
                <field name="aula"/>
                <field name="tutor_id"/>
            </tree>
        </field>
    </record>

    <record id="view_grupo_form" model="ir.ui.view">
        <field name="name">gestion.grupo.form</field>
        <field name="model">gestion.grupo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="nombre" string="Código del Grupo"/>
                        <h1><field name="nombre"/></h1>
                        <label for="denominacion" string="Nombre Completo"/>
                        <h2><field name="denominacion"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="aula"/>
                        </group>
                        <group>
                            <field name="tutor_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>