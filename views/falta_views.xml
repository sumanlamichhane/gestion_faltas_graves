<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_falta_tree" model="ir.ui.view">
            <field name="name">gestion.falta.tree</field>
            <field name="model">gestion.falta</field>
            <field name="arch" type="xml">
                <tree decoration-danger="estado in ('borrador', 'en_instruccion')" 
                      decoration-muted="estado in ('cerrado', 'resuelto')" 
                      decoration-success="estado=='resuelto'"
                      sample="1">
                    <field name="numero_parte"/>
                    <field name="fecha_hora"/>
                    <field name="alumno_id" widget="many2one_avatar"/>
                    <field name="grupo_id"/>
                    <field name="motivo_id"/>
                    <field name="lugar"/>
                    <field name="profesor_id"/>
                    <field name="estado" widget="badge" 
                           decoration-info="estado == 'borrador'"
                           decoration-warning="estado == 'en_instruccion'"
                           decoration-success="estado == 'resuelto'"/>
                </tree>
            </field>
        </record>

        <record id="view_falta_form" model="ir.ui.view">
            <field name="name">gestion.falta.form</field>
            <field name="model">gestion.falta</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_iniciar_instruccion" string="Iniciar Instrucción" type="object" 
                                states="borrador" class="oe_highlight"/>
                        <button name="action_resolver_falta" string="Resolver" type="object" 
                                states="en_instruccion" class="oe_highlight"/>
                        <button name="action_cerrar_falta" string="Cerrar Incidencia" type="object" 
                                states="borrador,en_instruccion,resuelto"/>
                        <button name="action_reabrir_falta" string="Reabrir" type="object" 
                                states="cerrado,resuelto" groups="base.group_no_one"/>
                        
                        <field name="estado" widget="statusbar" statusbar_visible="borrador,en_instruccion,resuelto,cerrado"/>
                    </header>
                    <sheet>
                        <widget name="web_ribbon" title="Cerrado" bg_color="bg-danger"
                                attrs="{'invisible': [('estado', '!=', 'cerrado')]}"/>
                        <widget name="web_ribbon" title="Resuelto" bg_color="bg-success"
                                attrs="{'invisible': [('estado', '!=', 'resuelto')]}"/>

                        <div class="oe_title">
                            <h1>
                                <field name="numero_parte" readonly="1"/>
                            </h1>
                            <h2 style="color: #7C7BAD;">
                                <field name="alumno_id" options="{'no_create': True}" placeholder="Selecciona Alumno"/>
                            </h2>
                            <div style="font-size: 14px; color: #666;">
                                <span class="fa fa-users"/> Grupo: <field name="grupo_id" readonly="1" class="oe_inline"/> | 
                                <span class="fa fa-id-card"/> NIA: <field name="nia" class="oe_inline"/>
                            </div>
                        </div>

                        <group>
                            <group string="Detalles del Suceso">
                                <field name="fecha_hora"/>
                                <field name="lugar"/>
                                <field name="motivo_id" options="{'no_create': True}"/>
                                <field name="asignatura_id" attrs="{'invisible': [('lugar', '!=', 'aula')]}"/>
                            </group>
                            <group string="Responsable">
                                <field name="profesor_id" readonly="0"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Hechos y Testigos">
                                <group>
                                    <field name="descripcion_hechos" placeholder="Describa detalladamente lo ocurrido..." style="min-height: 100px;"/>
                                    <field name="testigos" placeholder="Nombres de los testigos..."/>
                                </group>
                            </page>
                            
                            <page string="Comunicación con Familia">
                                <group>
                                    <group>
                                        <field name="llamada_familia" widget="radio"/>
                                        <field name="fecha_llamada" attrs="{'invisible': [('llamada_familia', '=', 'no_llamada')]}"/>
                                    </group>
                                    <group>
                                        <field name="observaciones_familia" placeholder="Comentarios de los padres..."/>
                                    </group>
                                </group>
                            </page>

                            <page string="Resolución y Medidas">
                                <group>
                                    <field name="medidas_iniciales" placeholder="Medidas tomadas por el profesor..."/>
                                    <field name="observaciones_directiva" placeholder="Resolución final de jefatura de estudios..."/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!--vista de busqueda-->
        <record id="view_falta_search" model="ir.ui.view">
            <field name="name">gestion.falta.search</field>
            <field name="model">gestion.falta</field>
            <field name="arch" type="xml">
                <search>
                    <field name="alumno_id"/>
                    <field name="nia"/>
                    <field name="profesor_id"/>
                    <filter string="Mis Partes" name="my_faults" domain="[('create_uid', '=', uid)]"/>
                    <separator/>
                    <filter string="Abiertos" name="open_faults" domain="[('estado', 'in', ('borrador', 'en_instruccion'))]"/>
                    <filter string="Cerrados" name="closed_faults" domain="[('estado', 'in', ('cerrado', 'resuelto'))]"/>
                    <group expand="0" string="Agrupar Por">
                        <filter string="Alumno" name="group_student" context="{'group_by': 'alumno_id'}"/>
                        <filter string="Estado" name="group_state" context="{'group_by': 'estado'}"/>
                        <filter string="Lugar" name="group_location" context="{'group_by': 'lugar'}"/>
                        <filter string="Fecha" name="group_date" context="{'group_by': 'fecha_hora:month'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!--vista de calendario-->
        <record id="view_falta_calendar" model="ir.ui.view">
            <field name="name">gestion.falta.calendar</field>
            <field name="model">gestion.falta</field>
            <field name="arch" type="xml">
                <calendar string="Calendario de Faltas" date_start="fecha_hora" color="estado" mode="month">
                    <field name="alumno_id"/>
                    <field name="lugar"/>
                    <field name="estado"/>
                </calendar>
            </field>
        </record>
        <!--vista de grafica-->
        <record id="view_falta_graph" model="ir.ui.view">
            <field name="name">gestion.falta.graph</field>
            <field name="model">gestion.falta</field>
            <field name="arch" type="xml">
                <graph string="Análisis de Faltas" type="bar" stacked="True">
                    <field name="grupo_id" type="row"/>
                    <field name="alumno_id" type="row"/>
                    <field name="motivo_id" type="row"/>
                    <field name="estado" type="col"/>
                </graph>
            </field>
        </record>
        <!--vista de kanban para faltas-->
        <record id="view_falta_kanban" model="ir.ui.view">
            <field name="name">gestion.falta.kanban</field>
            <field name="model">gestion.falta</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1">
                    <field name="numero_parte"/>
                    <field name="alumno_id"/>
                    <field name="fecha_hora"/>
                    <field name="estado"/>
                    <field name="profesor_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <span>
                                                <field name="numero_parte"/> - <field name="alumno_id"/>
                                            </span>
                                        </strong>
                                    </div>
                                    <field name="estado" widget="label_selection" options="{'classes': {'borrador': 'default', 'en_instruccion': 'warning', 'resuelto': 'success', 'cerrado': 'danger'}}"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <span class="fa fa-clock-o"/> <field name="fecha_hora"/>
                                    <br/>
                                    <span class="fa fa-user"/> <field name="profesor_id"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>