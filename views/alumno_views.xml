<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_alumno_tree" model="ir.ui.view">
        <field name="name">gestion.alumno.tree</field>
        <field name="model">gestion.alumno</field>
        <field name="arch" type="xml">
            <tree>
                <field name="nombre"/>
                <field name="nia"/>
                <field name="grupo_id"/>
                <field name="total_faltas" decoration-danger="total_faltas > 0"/>
            </tree>
        </field>
    </record>

    <record id="view_alumno_form" model="ir.ui.view">
        <field name="name">gestion.alumno.form</field>
        <field name="model">gestion.alumno</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="foto" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="nombre" class="oe_edit_only"/>
                        <h1><field name="nombre"/></h1>
                    </div>
                    <group>
                        <group string="Datos Académicos">
                            <field name="nia"/>
                            <field name="grupo_id"/>
                            <field name="total_faltas"/>
                        </group>
                        <group string="Contacto">
                            <field name="dni"/>
                            <field name="telefono1"/>
                            <field name="telefono2"/>
                            <field name="email1" widget="email"/>
                        </group>
                    </group>
                    <group string="Localización">
                        <field name="domicilio"/>
                        <group>
                            <field name="numero"/>
                            <field name="piso"/>
                        </group>
                        <group>
                            <field name="localidad"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Historial de Faltas">
                            <field name="falta_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>