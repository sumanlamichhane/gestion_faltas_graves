<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_alumno_tree" model="ir.ui.view">
            <field name="name">gestion.alumno.tree</field>
            <field name="model">gestion.alumno</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="nombre"/>
                    <field name="nia"/>
                    <field name="grupo_id"/>
                </tree>
            </field>
        </record>

        <record id="view_alumno_form" model="ir.ui.view">
            <field name="name">gestion.alumno.form</field>
            <field name="model">gestion.alumno</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="nombre" class="oe_edit_only" string="Nombre Completo del Alumno"/>
                            <h1><field name="nombre" placeholder="Ej: Juan Pérez García"/></h1>
                        </div>
                        <group>
                            <group string="Datos de Identificación">
                                <field name="nia" placeholder="Número de Identificación"/>
                                <field name="grupo_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>