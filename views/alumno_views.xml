<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_alumno_tree" model="ir.ui.view">
            <field name="name">gestion.alumno.tree</field>
            <field name="model">gestion.alumno</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="nombre"/>
                    <field name="nia"/>
                    <field name="grupo_id"/>
                </tree>
            </field>
        </record>

        <record id="view_alumno_form" model="ir.ui.view">
            <field name="name">gestion.alumno.form</field>
            <field name="model">gestion.alumno</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="nombre" class="oe_edit_only" string="Nombre Completo del Alumno"/>
                            <h1><field name="nombre" placeholder="Ej: Juan Pérez García"/></h1>
                        </div>
                        <group>
                            <group string="Datos de Identificación">
                                <field name="nia" placeholder="Número de Identificación"/>
                                <field name="grupo_id" options="{'no_create': True, 'no_open': True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_alumno_kanban" model="ir.ui.view">
            <field name="name">gestion.alumno.kanban</field>
            <field name="model">gestion.alumno</field>
            <field name="arch" type="xml">
                <kanban>
                    <field name="id"/>
                    <field name="nombre"/>
                    <field name="nia"/>
                    <field name="grupo_id"/>
                    <field name="foto"/>
                    <field name="total_faltas"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('gestion.alumno', 'foto', record.id.raw_value)" class="o_image_64_contain" alt="Alumno"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title"><field name="nombre"/></strong>
                                    <div><span class="fa fa-id-card"/> <field name="nia"/></div>
                                    <div><span class="fa fa-users"/> <field name="grupo_id"/></div>
                                    <div class="mt-2">
                                        <span class="badge badge-danger" t-if="record.total_faltas.raw_value &gt; 0">
                                            <i class="fa fa-exclamation-triangle"/> <field name="total_faltas"/> Faltas
                                        </span>
                                        <span class="badge badge-success" t-if="record.total_faltas.raw_value == 0">
                                            Sin Faltas
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
    </data>
</odoo>