<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <menuitem id="menu_gestion_faltas_root"
                  name="Gestión de Faltas"
                  web_icon="gestion_faltas_graves,static/description/icon.png"
                  sequence="1"/>

        <menuitem id="menu_gestion_faltas_gestion"
                  name="Gestión de faltas"
                  parent="menu_gestion_faltas_root"
                  sequence="10"/>

        <record id="action_mis_partes" model="ir.actions.act_window">
            <field name="name">Mis partes</field>
            <field name="res_model">gestion.falta</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('create_uid', '=', uid)]</field>
        </record>

        <menuitem id="menu_gestion_faltas_mis_partes"
                name="Mis partes"
                parent="menu_gestion_faltas_gestion"
                action="action_mis_partes"
                sequence="11"/>

        <record id="action_todos_partes" model="ir.actions.act_window">
            <field name="name">Todos los partes</field>
            <field name="res_model">gestion.falta</field>
            <field name="view_mode">tree,form,calendar,kanban,graph</field>
        </record>

        <menuitem id="menu_gestion_faltas_todos_partes"
                  name="Todos los partes"
                  parent="menu_gestion_faltas_gestion"
                  action="action_todos_partes"
                  groups="gestion_faltas_graves.group_gestion_profesor"
                  sequence="12"/>

        <menuitem id="menu_gestion_faltas_config"
                  name="Configuración"
                  parent="menu_gestion_faltas_root"
                  groups="gestion_faltas_graves.group_gestion_profesor"
                  sequence="20"/>

        <record id="action_alumnos" model="ir.actions.act_window">
            <field name="name">Alumnos</field>
            <field name="res_model">gestion.alumno</field>
            <field name="view_mode">kanban,tree,form</field>
        </record>

        <menuitem id="submenu_alumnos"
                  name="Alumnos"
                  parent="menu_gestion_faltas_config"
                  action="action_alumnos"
                  groups="gestion_faltas_graves.group_gestion_profesor"
                  sequence="1"/>

        <record id="view_profesor_form" model="ir.ui.view">
            <field name="name">gestion.profesor.form</field>
            <field name="model">gestion.profesor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="nombre"/>
                                <field name="dni"/>
                            </group>
                            <group>
                                <field name="usuario_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_profesores" model="ir.actions.act_window">
            <field name="name">Profesores</field>
            <field name="res_model">gestion.profesor</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="submenu_profesores"
                  name="Profesores"
                  parent="menu_gestion_faltas_config"
                  action="action_profesores"
                  groups="gestion_faltas_graves.group_gestion_jefe_estudios"
                  sequence="2"/>

        <record id="action_grupos" model="ir.actions.act_window">
            <field name="name">Grupos y aulas</field>
            <field name="res_model">gestion.grupo</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="submenu_grupos"
                  name="Grupos y aulas"
                  parent="menu_gestion_faltas_config"
                  action="action_grupos"
                  groups="gestion_faltas_graves.group_gestion_jefe_estudios"
                  sequence="3"/>

        <record id="action_asignaturas" model="ir.actions.act_window">
            <field name="name">Asignaturas</field>
            <field name="res_model">gestion.asignatura</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="submenu_asignaturas"
                  name="Asignaturas"
                  parent="menu_gestion_faltas_config"
                  action="action_asignaturas" 
                  groups="gestion_faltas_graves.group_gestion_jefe_estudios"
                  sequence="4"/>

        <record id="action_infraccion" model="ir.actions.act_window">
            <field name="name">Infracción grave</field>
            <field name="res_model">gestion.motivo</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[('es_grave', '=', True)]</field>
        </record>

        <menuitem id="submenu_motivos"
                  name="Motivos y Sanciones"
                  parent="menu_gestion_faltas_config"
                  action="action_infraccion"
                  groups="gestion_faltas_graves.group_gestion_jefe_estudios"
                  sequence="5"/>

        <menuitem id="menu_gestion_faltas_informes"
                  name="Informes y estadísticas"
                  parent="menu_gestion_faltas_root"
                  groups="gestion_faltas_graves.group_gestion_profesor"
                  sequence="30"/>

        <record id="action_analisis" model="ir.actions.act_window">
            <field name="name">Análisis gráfico</field>
            <field name="res_model">gestion.falta</field>
            <field name="view_mode">tree,form,graph,pivot</field>
        </record>

        <menuitem id="submenu_analisis"
                  name="Análisis gráfico"
                  parent="menu_gestion_faltas_informes"
                  action="action_analisis"
                  groups="gestion_faltas_graves.group_gestion_jefe_estudios"
                  sequence="1"/>

        <record id="action_reportes" model="ir.actions.act_window">
            <field name="name">Reportes PDF</field>
            <field name="res_model">gestion.falta</field>
            <field name="view_mode">tree</field>
        </record>

        <menuitem id="submenu_reportes"
                  name="Reportes PDF"
                  parent="menu_gestion_faltas_informes"
                  action="action_reportes"
                  groups="gestion_faltas_graves.group_gestion_profesor"
                  sequence="2"/>
    </data>
</odoo>