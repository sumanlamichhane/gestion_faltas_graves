<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_motivo_tree" model="ir.ui.view">
            <field name="name">gestion.motivo.tree</field>
            <field name="model">gestion.motivo</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="codigo"/>
                    <field name="descripcion"/>
                    <field name="dias_sancion_min"/>
                    <field name="dias_sancion_max"/>
                </tree>
            </field>
        </record>
        <record id="view_motivo_form" model="ir.ui.view">
            <field name="name">gestion.motivo.form</field>
            <field name="model">gestion.motivo</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="codigo"/>
                            <field name="descripcion"/>
                            <field name="dias_sancion_min"/>
                            <field name="dias_sancion_max"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
