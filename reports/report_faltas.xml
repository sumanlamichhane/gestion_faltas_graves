<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_faltas_ajustado" model="report.paperformat">
        <field name="name">Formato Faltas Ajustado</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">28</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_partes_graves" model="ir.actions.report">
        <field name="name">Informe de Partes Graves</field>
        <field name="model">gestion.falta</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_faltas_graves.report_falta_template</field>
        <field name="report_file">gestion_faltas_graves.report_falta_template</field>
        <field name="print_report_name">'Parte_%s_%s' % (object.numero_parte, object.alumno_id.nombre)</field>
        <field name="binding_model_id" ref="model_gestion_falta"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_faltas_ajustado"/>
    </record>

    <record id="action_report_resumen_faltas" model="ir.actions.report">
        <field name="name">Resumen de Partes Activos</field>
        <field name="model" eval="'gestion.falta'"/>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_faltas_graves.report_resumen_template</field>
        <field name="binding_model_id" ref="model_gestion_falta"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_faltas_ajustado"/>
    </record>

    <record id="action_report_alumno_faltas" model="ir.actions.report">
        <field name="name">Historial de Partes</field>
        <field name="model">gestion.alumno</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_faltas_graves.report_alumno_faltas_template</field>
        <field name="report_file">gestion_faltas_graves.report_alumno_faltas_template</field>
        <field name="print_report_name">'Historial_%s' % (object.nombre)</field>
        <field name="binding_model_id" ref="model_gestion_alumno"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_faltas_ajustado"/>
    </record>

    <record id="action_report_grupo_faltas" model="ir.actions.report">
        <field name="name">Informe de Faltas por Grupo</field>
        <field name="model">gestion.grupo</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_faltas_graves.report_grupo_template</field>
        <field name="print_report_name">'Faltas_Grupo_%s' % (object.nombre)</field>
        <field name="binding_model_id" ref="model_gestion_grupo"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_faltas_ajustado"/>
    </record>

    <record id="action_report_profesor_faltas" model="ir.actions.report">
        <field name="name">Informe de Faltas por Profesor</field>
        <field name="model">gestion.profesor</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestion_faltas_graves.report_profesor_template</field>
        <field name="print_report_name">'Faltas_Profesor_%s' % (object.nombre)</field>
        <field name="binding_model_id" ref="model_gestion_profesor"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_faltas_ajustado"/>
    </record>

    <template id="report_falta_template">
        <t t-call="web.html_container">
            <t t-if="len(docs) == 1">
                <t t-foreach="docs" t-as="o">
                    <t t-call="gestion_faltas_graves.report_falta_detalle_template"/>
                </t>
            </t>
            <t t-else="">
                <t t-call="gestion_faltas_graves.report_resumen_template"/>
            </t>
        </t>
    </template>

    <template id="report_falta_detalle_template">
        <t t-call="web.basic_layout">
            <div class="page" style="font-family: 'Helvetica'; font-size: 13px; color: #2c3e50;">
                <div class="row mb-2">
                    <div class="col-12"><img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 65px;"/></div>
                </div>
                <div style="border-bottom: 2px solid #004a99; margin-bottom: 12px;">
                    <div class="row">
                        <div class="col-9">
                            <h2 style="color: #004a99; font-weight: bold; margin: 0; font-size: 24px;">INFORME DE FALTA GRAVE</h2>
                            <p style="margin: 0; color: #7f8c8d;">Referencia: <span t-field="o.numero_parte"/></p>
                        </div>
                        <div class="col-3 text-right">
                            <div style="padding: 4px; display: inline-block;">
                                <span style="font-size: 9px; font-weight: bold; display: block; color: #004a99;">ESTADO</span>
                                <span style="font-weight: bold;" t-field="o.estado"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-6">
                        <h6 style="color: #004a99; font-weight: bold; border-bottom: 1px solid #eee; font-size: 12px;">DATOS DEL ALUMNO</h6>
                        <p style="margin-bottom: 1px;"><strong>Nombre:</strong> <span t-field="o.alumno_id.nombre"/></p>
                        <p style="margin-bottom: 1px;"><strong>NIA:</strong> <span t-field="o.nia"/></p>
                        <p style="margin-bottom: 1px;"><strong>Grupo:</strong> <span t-field="o.grupo_id.nombre"/></p>
                    </div>
                    <div class="col-6" style="border-left: 1px solid #eee;">
                        <h6 style="color: #004a99; font-weight: bold; border-bottom: 1px solid #eee; font-size: 12px;">DETALLES DEL INCIDENTE</h6>
                        <p style="margin-bottom: 1px;"><strong>Fecha y Hora:</strong> <span t-field="o.fecha_hora"/></p>
                        <p style="margin-bottom: 1px;"><strong>Lugar:</strong> <span style="text-transform: capitalize;" t-field="o.lugar"/></p>
                        <p style="margin-bottom: 1px;"><strong>Profesor:</strong> <span t-field="o.profesor_id.nombre"/></p>
                    </div>
                </div>
                <div style="background-color: #f8f9fa; border: 1px solid #dee2e6; padding: 8px; border-radius: 5px; margin-bottom: 12px;">
                    <p style="margin-bottom: 1px;"><strong>Motivo:</strong> <span t-field="o.motivo_id.descripcion"/> (<span t-field="o.motivo_id.codigo"/>)</p>
                    <p t-if="o.asignatura_id" style="margin-bottom: 1px;"><strong>Asignatura:</strong> <span t-field="o.asignatura_id.nombre"/></p>
                </div>
                <div class="mb-2">
                    <h6 style="color: #004a99; font-weight: bold; font-size: 12px;">DESCRIPCIÓN DE LOS HECHOS</h6>
                    <div style="border: 1px solid #eee; padding: 6px; border-radius: 4px; min-height: 35px; background-color: #fff;">
                        <span t-field="o.descripcion_hechos"/>
                    </div>
                </div>
                <div style="margin-top: 100px; width: 100%;">
                    <div style="float: left; width: 42%; text-align: center; border-top: 1px solid #2c3e50;">Firma Alumno/Tutor</div>
                    <div style="float: right; width: 42%; text-align: center; border-top: 1px solid #2c3e50;">Jefatura de Estudios</div>
                </div>
            </div>
        </t>
    </template>

    <template id="report_resumen_template">
        <t t-call="web.basic_layout">
            <div class="page" style="font-family: 'Helvetica'; font-size: 13px; color: #2c3e50;">
                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 65px;"/>
                <div style="border-bottom: 2px solid #004a99; margin-bottom: 15px;">
                    <h2 style="color: #004a99; font-weight: bold; margin: 0; font-size: 24px;">RESUMEN DE PARTES</h2>
                </div>
                <table class="table table-sm" style="width: 100%;">
                    <thead>
                        <tr style="background-color: #004a99; color: white;">
                            <th style="padding: 8px;">Nº PARTE</th><th style="padding: 8px;">ALUMNO</th><th style="padding: 8px;">FECHA</th><th style="padding: 8px;">MOTIVO</th><th style="padding: 8px;">ESTADO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="docs" t-as="o">
                            <tr style="border-bottom: 1px solid #dee2e6;">
                                <td style="padding: 8px;"><strong><span t-field="o.numero_parte"/></strong></td>
                                <td style="padding: 8px;"><span t-field="o.alumno_id.nombre"/></td>
                                <td style="padding: 8px;"><span t-field="o.fecha_hora" t-options='{"widget": "date"}'/></td>
                                <td style="padding: 8px;"><span t-field="o.motivo_id.descripcion"/></td>
                                <td style="padding: 8px;"><span t-field="o.estado"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>

    <template id="report_alumno_faltas_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="alumno">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: 'Helvetica'; font-size: 13px; color: #2c3e50;">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 65px;"/>
                        <div style="border-bottom: 2px solid #004a99; margin-bottom: 15px;">
                            <h2 style="color: #004a99; font-weight: bold; margin: 0; font-size: 24px;">HISTORIAL DE PARTES</h2>
                        </div>
                        <div style="background-color: #f8f9fa; border: 1px solid #dee2e6; padding: 12px; border-radius: 5px; margin-bottom: 20px;">
                            <h6 style="color: #004a99; font-weight: bold; border-bottom: 1px solid #eee; margin-bottom: 8px;">DATOS DEL ALUMNO</h6>
                            <div class="row">
                                <div class="col-4"><strong>Nombre:</strong> <span t-field="alumno.nombre"/></div>
                                <div class="col-4"><strong>NIA:</strong> <span t-field="alumno.nia"/></div>
                                <div class="col-4"><strong>Grupo:</strong> <span t-field="alumno.grupo_id.nombre"/></div>
                            </div>
                        </div>
                        <table class="table table-sm" style="width: 100%;">
                            <thead>
                                <tr style="background-color: #004a99; color: white;">
                                    <th style="padding: 8px;">Nº PARTE</th><th style="padding: 8px;">FECHA</th><th style="padding: 8px;">MOTIVO</th><th style="padding: 8px;">PROFESOR</th><th style="padding: 8px;">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="alumno.falta_ids" t-as="falta">
                                    <tr style="border-bottom: 1px solid #dee2e6;">
                                        <td style="padding: 8px;"><strong><span t-field="falta.numero_parte"/></strong></td>
                                        <td style="padding: 8px;"><span t-field="falta.fecha_hora" t-options='{"widget": "date"}'/></td>
                                        <td style="padding: 8px;"><span t-field="falta.motivo_id.descripcion"/></td>
                                        <td style="padding: 8px;"><span t-field="falta.profesor_id.nombre"/></td>
                                        <td style="padding: 8px;"><span t-field="falta.estado"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_grupo_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="grupo">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: 'Helvetica'; font-size: 13px; color: #2c3e50;">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 65px;"/>
                        <div style="border-bottom: 2px solid #004a99; margin-bottom: 15px;">
                            <h2 style="color: #004a99; font-weight: bold; margin: 0; font-size: 24px;">INFORME DE FALTAS POR GRUPO</h2>
                        </div>
                        <div style="background-color: #f8f9fa; border: 1px solid #dee2e6; padding: 12px; border-radius: 5px; margin-bottom: 20px;">
                            <h6 style="color: #004a99; font-weight: bold; border-bottom: 1px solid #eee; margin-bottom: 8px;">DATOS DEL GRUPO</h6>
                            <div class="row">
                                <div class="col-6"><strong>Grupo:</strong> <span t-field="grupo.nombre"/></div>
                                <div class="col-6"><strong>Total Partes:</strong> <span t-esc="len(grupo.falta_ids)"/></div>
                            </div>
                        </div>
                        <table class="table table-sm" style="width: 100%;">
                            <thead>
                                <tr style="background-color: #004a99; color: white;">
                                    <th style="padding: 8px;">Nº PARTE</th><th style="padding: 8px;">ALUMNO</th><th style="padding: 8px;">FECHA</th><th style="padding: 8px;">MOTIVO</th><th style="padding: 8px;">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="grupo.falta_ids" t-as="f">
                                    <tr style="border-bottom: 1px solid #dee2e6;">
                                        <td style="padding: 8px;"><strong><span t-field="f.numero_parte"/></strong></td>
                                        <td style="padding: 8px;"><span t-field="f.alumno_id.nombre"/></td>
                                        <td style="padding: 8px;"><span t-field="f.fecha_hora" t-options='{"widget": "date"}'/></td>
                                        <td style="padding: 8px;"><span t-field="f.motivo_id.descripcion"/></td>
                                        <td style="padding: 8px;"><span t-field="f.estado"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <template id="report_profesor_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="profesor">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: 'Helvetica'; font-size: 13px; color: #2c3e50;">
                        <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 65px;"/>
                        <div style="border-bottom: 2px solid #004a99; margin-bottom: 15px;">
                            <h2 style="color: #004a99; font-weight: bold; margin: 0; font-size: 24px;">INFORME DE FALTAS POR PROFESOR</h2>
                        </div>
                        <div style="background-color: #f8f9fa; border: 1px solid #dee2e6; padding: 12px; border-radius: 5px; margin-bottom: 20px;">
                            <h6 style="color: #004a99; font-weight: bold; border-bottom: 1px solid #eee; margin-bottom: 8px;">DATOS DEL PROFESOR</h6>
                            <div class="row">
                                <div class="col-6"><strong>Profesor:</strong> <span t-field="profesor.nombre"/></div>
                                <div class="col-6"><strong>Partes Emitidos:</strong> <span t-esc="len(profesor.falta_ids)"/></div>
                            </div>
                        </div>
                        <table class="table table-sm" style="width: 100%;">
                            <thead>
                                <tr style="background-color: #004a99; color: white;">
                                    <th style="padding: 8px;">Nº PARTE</th><th style="padding: 8px;">ALUMNO</th><th style="padding: 8px;">GRUPO</th><th style="padding: 8px;">FECHA</th><th style="padding: 8px;">ESTADO</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="profesor.falta_ids" t-as="f">
                                    <tr style="border-bottom: 1px solid #dee2e6;">
                                        <td style="padding: 8px;"><strong><span t-field="f.numero_parte"/></strong></td>
                                        <td style="padding: 8px;"><span t-field="f.alumno_id.nombre"/></td>
                                        <td style="padding: 8px;"><span t-field="f.grupo_id.nombre"/></td>
                                        <td style="padding: 8px;"><span t-field="f.fecha_hora" t-options='{"widget": "date"}'/></td>
                                        <td style="padding: 8px;"><span t-field="f.estado"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>